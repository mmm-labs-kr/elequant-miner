# Elequant-Miner Configuration Example
# Copy this file to .env and fill in your actual credentials

# Gemini 백엔드 선택: aistudio (기본값) 또는 vertex
GEMINI_BACKEND=aistudio

# AI Studio 백엔드일 때 필요
GEMINI_API_KEY=your_gemini_api_key_here

# Vertex AI 백엔드일 때 필요 (GEMINI_BACKEND=vertex)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1

# WorldQuant Brain Credentials
WQ_EMAIL=your_email@example.com
WQ_PASSWORD=your_password_here
